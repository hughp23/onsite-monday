FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY src/OnsiteMonday.Api/OnsiteMonday.Api.csproj src/OnsiteMonday.Api/
RUN dotnet restore src/OnsiteMonday.Api/OnsiteMonday.Api.csproj

COPY . .
RUN dotnet publish src/OnsiteMonday.Api/OnsiteMonday.Api.csproj \
    -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "OnsiteMonday.Api.dll"]
