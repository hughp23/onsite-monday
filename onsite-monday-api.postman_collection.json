              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"rating\": 5,\n  \"text\": \"James was fantastic — arrived on time, clean job, and sorted the EICR too. Highly recommended.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "reviews"]
