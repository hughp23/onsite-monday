{
  "info": {
    "_postman_id": "om-api-collection-v1",
    "name": "Ônsite Monday API",
    "description": "Full API collection for the Ônsite Monday backend (.NET 8 / ASP.NET Core). Base URL: http://localhost:5236/api (dev) or https://api.onsitemonday.co.uk/api (prod).\n\nAuthentication: Firebase JWT. Set {{firebaseToken}} in the collection variables or environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebaseToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5236/api",
      "type": "string",
      "description": "API base URL. Change to https://api.onsitemonday.co.uk/api for production."
    },
    {
      "key": "firebaseApiKey",
      "value": "",
      "type": "string",
      "description": "Firebase Web API key. Found in Firebase Console → Project Settings → General → Web API Key."
    },
    {
      "key": "firebaseToken",
      "value": "",
      "type": "string",
      "description": "Firebase ID token. Populated automatically by the Sign Up / Sign In test scripts."
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "A target user's ID (GUID). Set after fetching /users/me or /users/tradespeople."
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string",
      "description": "A job ID (GUID). Set after creating or listing jobs."
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string",
      "description": "A conversation ID (GUID). Set after creating or listing conversations."
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string",
      "description": "A notification ID (GUID). Set after listing notifications."
    }
  ],
  "item": [
    {
      "name": "Auth (Firebase)",
      "description": "Firebase Identity Toolkit REST API calls for sign-up and sign-in. These hit Google's servers directly — not the Ônsite Monday backend. The test scripts automatically copy the returned idToken into the {{firebaseToken}} collection variable so all subsequent requests are authenticated.",
      "item": [
        {
          "name": "Sign Up (Email & Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.idToken) {",
                  "    pm.collectionVariables.set('firebaseToken', json.idToken);",
                  "    console.log('firebaseToken set from sign-up response.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"password\": \"Password1!\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebaseApiKey}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signUp"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseApiKey}}"
                }
              ]
            },
            "description": "Creates a new Firebase account with email and password.\n\nThe **Tests** script automatically saves the returned `idToken` to `{{firebaseToken}}` so all backend requests are immediately authenticated.\n\nAfter a successful sign-up, call **Get Current User** (`GET /users/me`) — the backend will auto-create the user record on first call using the Firebase UID."
          },
          "response": [
            {
              "name": "200 OK — Account Created",
              "originalRequest": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"password\": \"Password1!\",\n  \"returnSecureToken\": true\n}"
                },
                "url": {
                  "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebaseApiKey}}"
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"kind\": \"identitytoolkit#SignupNewUserResponse\",\n  \"localId\": \"abc123uid\",\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"idToken\": \"<Firebase ID token — valid for 1 hour>\",\n  \"refreshToken\": \"<Firebase refresh token>\",\n  \"expiresIn\": \"3600\"\n}"
            },
            {
              "name": "400 Bad Request — Email Already In Use",
              "originalRequest": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"password\": \"Password1!\",\n  \"returnSecureToken\": true\n}"
                },
                "url": {
                  "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{firebaseApiKey}}"
                }
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"error\": {\n    \"code\": 400,\n    \"message\": \"EMAIL_EXISTS\",\n    \"errors\": [\n      {\n        \"message\": \"EMAIL_EXISTS\",\n        \"domain\": \"global\",\n        \"reason\": \"invalid\"\n      }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Sign In (Email & Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.idToken) {",
                  "    pm.collectionVariables.set('firebaseToken', json.idToken);",
                  "    console.log('firebaseToken set from sign-in response.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"password\": \"Password1!\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseApiKey}}"
                }
              ]
            },
            "description": "Signs in an existing Firebase account with email and password. The **Tests** script automatically saves the returned `idToken` to `{{firebaseToken}}`.\n\nID tokens expire after 1 hour. Use **Refresh Token** to get a new one without signing in again."
          },
          "response": [
            {
              "name": "200 OK — Signed In",
              "originalRequest": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"password\": \"Password1!\",\n  \"returnSecureToken\": true\n}"
                },
                "url": {
                  "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}"
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"kind\": \"identitytoolkit#VerifyPasswordResponse\",\n  \"localId\": \"abc123uid\",\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"displayName\": \"\",\n  \"idToken\": \"<Firebase ID token — valid for 1 hour>\",\n  \"registered\": true,\n  \"refreshToken\": \"<Firebase refresh token>\",\n  \"expiresIn\": \"3600\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id_token) {",
                  "    pm.collectionVariables.set('firebaseToken', json.id_token);",
                  "    console.log('firebaseToken refreshed.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token" },
                { "key": "refresh_token", "value": "<paste refreshToken from sign-in response>" }
              ]
            },
            "url": {
              "raw": "https://securetoken.googleapis.com/v1/token?key={{firebaseApiKey}}",
              "protocol": "https",
              "host": ["securetoken", "googleapis", "com"],
              "path": ["v1", "token"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseApiKey}}"
                }
              ]
            },
            "description": "Exchanges a Firebase refresh token for a new ID token. Use this when the `idToken` has expired (after 1 hour) rather than signing in again. Paste the `refreshToken` value from the sign-in response into the body."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
