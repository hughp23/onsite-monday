              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Unauthenticated liveness check. Returns 200 OK when the API is running."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/health" }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{ \"status\": \"healthy\" }"
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Returns the authenticated user's profile. Auto-creates a new user record on first call (using the Firebase UID from the JWT)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/users/me" }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"firstName\": \"James\",\n  \"lastName\": \"Hartley\",\n  \"businessName\": \"Hartley Electrical Ltd\",\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"phone\": \"07712345678\",\n  \"trade\": \"Electrician\",\n  \"skills\": [\"18th Edition\", \"EV Charging\"],\n  \"accreditations\": [\"NICEIC\", \"Part P\"],\n  \"dayRate\": 320,\n  \"dayRateVisible\": true,\n  \"location\": \"Manchester\",\n  \"travelRadius\": 30,\n  \"rating\": 4.8,\n  \"reviewCount\": 12,\n  \"profileImageUrl\": null,\n  \"gallery\": [],\n  \"isOnboarded\": true,\n  \"subscription\": \"silver\"\n}"
            }
          ]
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"James\",\n  \"lastName\": \"Hartley\",\n  \"businessName\": \"Hartley Electrical Ltd\",\n  \"phone\": \"07712345678\",\n  \"trade\": \"Electrician\",\n  \"skills\": [\"18th Edition\", \"EV Charging\", \"Solar PV\"],\n  \"accreditations\": [\"NICEIC\", \"Part P\"],\n  \"dayRate\": 350,\n  \"dayRateVisible\": true,\n  \"location\": \"Manchester\",\n  \"travelRadius\": 40,\n  \"profileImageUrl\": null,\n  \"gallery\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Updates any combination of profile fields for the authenticated user. All fields are optional."
          }
        },
        {
          "name": "Complete Onboarding",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Prerequisite: the user's profile must have the required fields filled in",
                  "// before calling this endpoint. Run 'Update Current User' first if needed.",
                  "//",
                  "// Typical onboarding sequence:",
                  "//   1. Sign Up  →  creates Firebase account, sets {{firebaseToken}}",
                  "//   2. Get Current User (GET /users/me)  →  auto-creates DB record",
                  "//   3. Update Current User (PUT /users/me)  →  fills profile fields",
                  "//   4. Complete Onboarding (POST /users/me/onboard)  →  sets isOnboarded = true"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me/onboard",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me", "onboard"]
            },
            "description": "Marks the authenticated user's profile as onboarded (`isOnboarded = true`). Called at the end of the slide-by-slide onboarding flow.\n\n**Testing sequence:**\n1. Sign Up → get `{{firebaseToken}}`\n2. `GET /users/me` → auto-creates the DB record\n3. `PUT /users/me` → fill in all profile fields (trade, location, dayRate, etc.)\n4. Call this endpoint → `isOnboarded` flips to `true`\n\nReturns the full updated user profile."
          },
          "response": [
            {
              "name": "200 OK — Onboarding Complete",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/users/me/onboard"
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"firstName\": \"James\",\n  \"lastName\": \"Hartley\",\n  \"businessName\": \"Hartley Electrical Ltd\",\n  \"email\": \"james@hartleyelectrical.co.uk\",\n  \"phone\": \"07712345678\",\n  \"trade\": \"Electrician\",\n  \"skills\": [\"18th Edition\", \"EV Charging\", \"Solar PV\"],\n  \"accreditations\": [\"NICEIC\", \"Part P\"],\n  \"dayRate\": 320,\n  \"dayRateVisible\": true,\n  \"location\": \"Manchester\",\n  \"travelRadius\": 30,\n  \"rating\": 0,\n  \"reviewCount\": 0,\n  \"profileImageUrl\": null,\n  \"gallery\": [],\n  \"isOnboarded\": true,\n  \"subscription\": \"bronze\"\n}"
            },
            {
              "name": "409 Conflict — Already Onboarded",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/users/me/onboard"
                }
              },
              "status": "Conflict",
              "code": 409,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"error\": \"User is already onboarded.\"\n}"
            },
            {
              "name": "401 Unauthorized — Missing or Expired Token",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/users/me/onboard"
                }
              },
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"error\": \"Unauthorized\"\n}"
            }
          ]
        },
        {
          "name": "List Tradespeople",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/tradespeople?trade=Electrician&location=Manchester",
              "host": ["{{baseUrl}}"],
              "path": ["users", "tradespeople"],
              "query": [
                {
                  "key": "trade",
                  "value": "Electrician",
                  "description": "Filter by trade (e.g. Electrician, Plumber, Carpenter)"
                },
                {
                  "key": "location",
                  "value": "Manchester",
                  "description": "Filter by location string"
                }
              ]
            },
            "description": "Returns a list of tradesperson profiles. Both query parameters are optional."
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Returns a public profile for any user by their GUID."
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs?trade=Electrician&location=Manchester&status=open&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                {
                  "key": "trade",
                  "value": "Electrician",
                  "description": "Filter by trade"
                },
                {
                  "key": "location",
                  "value": "Manchester",
                  "description": "Filter by location string"
                },
                {
                  "key": "status",
                  "value": "open",
                  "description": "Filter by status: open | applied | accepted | in_progress | completed"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (1-based)"
                },
                {
                  "key": "pageSize",
                  "value": "20",
                  "description": "Results per page"
                }
              ]
            },
            "description": "Returns the jobs board feed. The isInterested flag on each job reflects whether the authenticated user has expressed interest. All query parameters are optional."
          }
        },
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Consumer Unit Upgrade\",\n  \"trade\": \"Electrician\",\n  \"location\": \"Manchester\",\n  \"postcode\": \"M1 2AB\",\n  \"duration\": 2,\n  \"days\": [\"Monday\", \"Tuesday\"],\n  \"startDate\": \"2026-05-01\",\n  \"endDate\": \"2026-05-02\",\n  \"startTime\": \"08:00\",\n  \"endTime\": \"17:00\",\n  \"dayRate\": 300,\n  \"description\": \"Replace existing fuseboard with a 24-way consumer unit and install SPD.\",\n  \"paymentTerms\": \"14 days after completion\",\n  \"photos\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/jobs",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"]
            },
            "description": "Creates a new job posting. The authenticated user becomes the job poster. Returns the created job with status 'open'."
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "{{jobId}}"]
            },
            "description": "Returns full detail for a single job including applicant count and whether the current user has expressed interest."
          }
        },
        {
          "name": "My Posted Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/my/posted",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "my", "posted"]
            },
            "description": "Returns all jobs posted by the authenticated user regardless of status."
          }
        },
        {
          "name": "My Accepted Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/my/accepted",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "my", "accepted"]
            },
            "description": "Returns all jobs the authenticated tradesperson has been accepted for (status = accepted or in_progress)."
          }
        },
        {
          "name": "Toggle Interest (Apply / Withdraw)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}/interest",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "{{jobId}}", "interest"]
            },
            "description": "Toggles the authenticated tradesperson's interest in a job. Creates a JobApplication if none exists; deletes it if one already exists. Returns the updated job."
          }
        },
        {
          "name": "Accept Applicant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicantId\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "{{jobId}}", "accept"]
            },
            "description": "Job poster accepts a tradesperson for the job. Transitions job status from open → accepted. Triggers fund-hold via Stripe stub."
          }
        },
        {
          "name": "Complete Job",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["jobs", "{{jobId}}", "complete"]
            },
            "description": "Marks a job as completed (accepted/in_progress → completed). After this, a mandatory review must be submitted to trigger payout release."
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Reviews for User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "reviews"]
            },
            "description": "Returns all reviews submitted for the given user, ordered by most recent first."
